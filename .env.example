# ─────────────────────────────────────────────────────────────────────────────
# FCDSA Meet 2026 — Environment Variables
# Copy this file to `.env.local` and fill in values from your Supabase project
# (Supabase Dashboard → Project Settings → API).
# ─────────────────────────────────────────────────────────────────────────────

# Public Supabase project URL. Safe to expose to the browser.
# Example: https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key. Safe to expose; RLS policies enforce access control.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key. SERVER-ONLY — bypasses RLS. NEVER expose to the browser,
# never prefix with NEXT_PUBLIC_. Used only by the seed script and trusted
# server-side admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL, used for SEO metadata / Open Graph absolute URLs.
# Local: http://localhost:3000  |  Prod: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Seed script only (optional) ──────────────────────────────────────────────
# Email + password for the initial admin user created by `npm run seed`.
# Change these before seeding a real environment.
SEED_ADMIN_EMAIL=admin@fcdsaa2026.local
SEED_ADMIN_PASSWORD=ChangeMe!2026
